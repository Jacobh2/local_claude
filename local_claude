#!/bin/bash
# local_claude — Run Claude Code backed by LM Studio
# Works from any directory. Isolated from your regular claude.ai auth.
# Routes through proxy.py for image support, haiku faking, and token counting.

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || echo "$0")")" && pwd)"
LOCAL_HOME="$HOME/.local_claude"
LM_STUDIO="http://localhost:1234"
PROXY="http://localhost:4000"
PROXY_PORT=4000
CONTEXT_LENGTH=262144
DEFAULT_MODEL="qwen3.5-122b-a10b@4bit"

# --- Setup isolated home (avoids auth conflict with claude.ai) ---
if [ ! -d "$LOCAL_HOME" ]; then
    mkdir -p "$LOCAL_HOME"
    for f in .gitconfig .ssh .config .npm .nvm .volta; do
        [ -e "$HOME/$f" ] && ln -sf "$HOME/$f" "$LOCAL_HOME/$f" 2>/dev/null
    done
fi

# --- Ensure model is loaded ---
ensure_model() {
    local model="$1"
    local loaded_ctx
    loaded_ctx=$(curl -s "$LM_STUDIO/api/v0/models" 2>/dev/null | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    for m in data['data']:
        if m['id'] == '$model' and m.get('state') == 'loaded':
            print(m.get('loaded_context_length', 0))
            break
except: pass
" 2>/dev/null)

    if [ "$loaded_ctx" = "$CONTEXT_LENGTH" ]; then
        echo "[local_claude] $model loaded (ctx=$CONTEXT_LENGTH)"
        return
    fi

    if [ -n "$loaded_ctx" ] && [ "$loaded_ctx" != "0" ]; then
        read -rp "[local_claude] $model is loaded with ctx=$loaded_ctx instead of $CONTEXT_LENGTH. Reload with ctx=$CONTEXT_LENGTH? [Y/n] " answer
    else
        read -rp "[local_claude] $model is not loaded. Load it with ctx=$CONTEXT_LENGTH? [Y/n] " answer
    fi
    if [[ "$answer" =~ ^[Nn] ]]; then
        echo "[local_claude] Aborted."
        exit 1
    fi

    echo "[local_claude] Loading $model (ctx=$CONTEXT_LENGTH)..."
    curl -s -X POST "$LM_STUDIO/api/v1/models/load" \
        -H "Content-Type: application/json" \
        -d "{\"model\": \"$model\", \"context_length\": $CONTEXT_LENGTH}" \
        --max-time 120 >/dev/null 2>&1
    echo "[local_claude] Model ready"
}

# --- Handle flags ---
CLAUDE_MODEL="$DEFAULT_MODEL"
if [ "$1" = "--model" ] && [ -n "$2" ]; then
    CLAUDE_MODEL="$2"
    shift 2
fi

if [ "$1" = "--ctx" ] && [ -n "$2" ]; then
    CONTEXT_LENGTH="$2"
    shift 2
fi

if [ "$1" = "--stop" ]; then
    if lsof -ti :$PROXY_PORT >/dev/null 2>&1; then
        kill $(lsof -ti :$PROXY_PORT) 2>/dev/null
        echo "[local_claude] Proxy stopped"
    else
        echo "[local_claude] Proxy not running"
    fi
    exit 0
fi

# --- Start proxy if not running ---
STARTED_PROXY=false

cleanup() {
    if $STARTED_PROXY && [ -n "$PROXY_PID" ] && kill -0 $PROXY_PID 2>/dev/null; then
        echo ""
        echo "[local_claude] Stopping proxy (pid=$PROXY_PID)..."
        kill $PROXY_PID 2>/dev/null
        wait $PROXY_PID 2>/dev/null
    fi
}
trap cleanup EXIT

start_proxy() {
    if lsof -ti :$PROXY_PORT >/dev/null 2>&1; then
        echo "[local_claude] Killing stale proxy on :$PROXY_PORT..."
        kill $(lsof -ti :$PROXY_PORT) 2>/dev/null
        sleep 0.5
    fi
    echo "[local_claude] Starting proxy on :$PROXY_PORT..."
    uv run --project "$SCRIPT_DIR" python "$SCRIPT_DIR/proxy.py" &
    PROXY_PID=$!
    sleep 1
    if kill -0 $PROXY_PID 2>/dev/null; then
        STARTED_PROXY=true
        echo "[local_claude] Proxy started (pid=$PROXY_PID)"
    else
        echo "[local_claude] WARNING: Proxy failed to start, falling back to direct mode"
        PROXY="$LM_STUDIO"
    fi
}

# --- Launch ---
ensure_model "$CLAUDE_MODEL"
start_proxy

echo "[local_claude] Proxy → LM Studio | $CLAUDE_MODEL (ctx=$CONTEXT_LENGTH)"
echo ""

HOME="$LOCAL_HOME" \
ANTHROPIC_BASE_URL="$PROXY" \
ANTHROPIC_AUTH_TOKEN="lmstudio" \
claude --model "$CLAUDE_MODEL" "$@"
